<Page x:Class="test.pages.ProductInfo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:test.pages"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="Товары"
      FontFamily="Calibri">

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel x:Name="ControlPanel"
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Height="55"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <TextBox x:Name="SearchTB"
                     Width="180"
                     Margin="5"
                     TextChanged="SearchTB_TextChanged"/>

            <ComboBox x:Name="FilterCB"
                      Width="150"
                      Margin="5"
                      SelectionChanged="FilterCB_SelectionChanged">

                <ComboBoxItem Content="Все диапазоны"/>
                <ComboBoxItem Content="0–11,99%"/>
                <ComboBoxItem Content="12–18,99%"/>
                <ComboBoxItem Content="19% и более"/>
            </ComboBox>

            <ComboBox x:Name="SortCB"
                      Width="190"
                      Margin="5"
                      SelectionChanged="SortCB_SelectionChanged">

                <ComboBoxItem Content="По умолчанию"/>
                <ComboBoxItem Content="Цена по возрастанию"/>
                <ComboBoxItem Content="Цена по убыванию"/>
                <ComboBoxItem Content="Количество по возрастанию"/>
                <ComboBoxItem Content="Количество по убыванию"/>
            </ComboBox>

            <Button x:Name="ResetButton"
                    Content="Сбросить"
                    Height="35"
                    Margin="5"
                    Click="ResetButton_Click"/>

            <Button x:Name="AddButton"
                    Content="Добавить"
                    Height="35"
                    Margin="5"
                    Click="AddButton_Click"/>

            <Button x:Name="DeleteButton"
                    Content="Удалить"
                    Height="35"
                    Margin="5"
                    Click="DeleteButton_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalAlignment="Center">

            <ListView x:Name="MainListView"
                      MouseDoubleClick="MainListView_MouseDoubleClick">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ItemBorder"
                                Background="#FFFFFF"
                                BorderBrush="Black"
                                BorderThickness="2"
                                Margin="2">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="500"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0"
                                   Source="{Binding FullImagePath}"
                                   Height="100"
                                   Width="100"
                                   Margin="10"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="0"
                                            Orientation="Vertical"
                                            Margin="10">

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="Bold"
                                                   Text="{Binding Article}"/>

                                        <TextBlock FontWeight="Bold"
                                                   Text=" - "/>

                                        <TextBlock FontWeight="Bold"
                                                   Text="{Binding Name}"/>

                                        <TextBlock FontWeight="Bold"
                                                   Text=" - "/>

                                        <TextBlock FontWeight="Bold"
                                                   Text="{Binding Category.Name}"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Description}"
                                               FontStyle="Italic"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{Binding Manufacturer.Name,
                                               StringFormat={}Производитель: {0}}"/>

                                    <TextBlock Text="{Binding Supplier.Name,
                                               StringFormat={}Поставщик: {0}}"/>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: "/>

                                        <TextBlock Text="{Binding Price}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDiscount}"
                                                                     Value="True">

                                                            <Setter Property="TextDecorations"
                                                                    Value="Strikethrough"/>

                                                            <Setter Property="Foreground"
                                                                    Value="Red"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Text=" Итоговая цена: "/>

                                        <TextBlock Text="{Binding FinalPrice}"
                                                   Foreground="Black">

                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDiscount}"
                                                                     Value="True">

                                                            <Setter Property="Visibility"
                                                                    Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="На складе: "/>
                                        <TextBlock Text="{Binding Amount}"/>
                                        <TextBlock Text=" "/>
                                        <TextBlock Text="{Binding Measurement.Name}"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Discount,
                                               StringFormat={}Скидка: {0}%}"/>
                                </StackPanel>

                                
                            </Grid>
                        </Border>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding BigDiscount}"
                                         Value="True">

                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#483D8B"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding OutOfStock}"
                                         Value="True">

                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#D3D3D3"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Page>