<Page x:Class="test.pages.ProductInfo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:test.pages"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="Товары"
      FontFamily="Calibri">

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel x:Name="ControlPanel"
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Height="55"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <TextBox x:Name="SearchTB"
                     Width="180"
                     Margin="5"
                     TextChanged="SearchTB_TextChanged"/>

            <ComboBox x:Name="FilterCB"
                      Width="150"
                      Margin="5"
                      SelectionChanged="FilterCB_SelectionChanged">

                <ComboBoxItem Content="Все диапазоны"/>
                <ComboBoxItem Content="0–11,99%"/>
                <ComboBoxItem Content="12–18,99%"/>
                <ComboBoxItem Content="19% и более"/>
            </ComboBox>

            <ComboBox x:Name="SortCB"
                      Width="190"
                      Margin="5"
                      SelectionChanged="SortCB_SelectionChanged">

                <ComboBoxItem Content="По умолчанию"/>
                <ComboBoxItem Content="Цена по возрастанию"/>
                <ComboBoxItem Content="Цена по убыванию"/>
                <ComboBoxItem Content="Количество по возрастанию"/>
                <ComboBoxItem Content="Количество по убыванию"/>
            </ComboBox>

            <Button x:Name="ResetButton"
                    Content="Сбросить"
                    Height="35"
                    Margin="5"
                    Click="ResetButton_Click"/>

            <Button x:Name="AddButton"
                    Content="Добавить"
                    Height="35"
                    Margin="5"
                    Click="AddButton_Click"/>

            <Button x:Name="DeleteButton"
                    Content="Удалить"
                    Height="35"
                    Margin="5"
                    Click="DeleteButton_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalAlignment="Center">

            <ListView x:Name="MainListView"
                      MouseDoubleClick="MainListView_MouseDoubleClick"
                      BorderThickness="0"
                      Background="Transparent">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch"/>

                        <Setter Property="Padding"
                                Value="0"/>

                        <Setter Property="Margin"
                                Value="0,2"/>

                        <Setter Property="BorderThickness"
                                Value="0"/>

                        <Setter Property="Background"
                                Value="Transparent"/>

                        <Setter Property="FocusVisualStyle"
                                Value="{x:Null}"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ItemBorder"
                                Background="#FFFFFF"
                                BorderBrush="Black"
                                BorderThickness="2"
                                Width="750"
                                MinHeight="130"
                                Margin="2">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>

                                <Image Grid.Column="0"
                                       Source="{Binding FullImagePath}"
                                       Height="100"
                                       Width="100"
                                       Margin="10"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1"
                                            Orientation="Vertical"
                                            Margin="10"
                                            VerticalAlignment="Center">

                                    <TextBlock FontWeight="Bold"
                                               TextWrapping="Wrap">
                                        <Run Text="{Binding Category.Name}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>

                                    <TextBlock TextWrapping="Wrap"
                                               Margin="0,4,0,0">
                                        <Run Text="Описание товара: "/>
                                        <Run Text="{Binding Description}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,2,0,0">
                                        <Run Text="Производитель: "/>
                                        <Run Text="{Binding Manufacturer.Name}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,2,0,0">
                                        <Run Text="Поставщик: "/>
                                        <Run Text="{Binding Supplier.Name}"/>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,2,0,0">
                                        <TextBlock Text="Цена: "/>

                                        <TextBlock Text="{Binding Price}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDiscount}"
                                                                     Value="True">

                                                            <Setter Property="TextDecorations"
                                                                    Value="Strikethrough"/>

                                                            <Setter Property="Foreground"
                                                                    Value="Red"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Text=" Итоговая цена: ">

                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDiscount}"
                                                                     Value="True">

                                                            <Setter Property="Visibility"
                                                                    Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Text="{Binding FinalPrice}">

                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDiscount}"
                                                                     Value="True">

                                                            <Setter Property="Visibility"
                                                                    Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <TextBlock Margin="0,2,0,0">
                                        <Run Text="Единица измерения: "/>
                                        <Run Text="{Binding Measurement.Name}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,2,0,0">
                                        <Run Text="Количество на складе: "/>
                                        <Run Text="{Binding Amount}"/>
                                    </TextBlock>
                                </StackPanel>

                                <Border Grid.Column="2"
                                        BorderBrush="Black"
                                        BorderThickness="1,0,0,0"
                                        VerticalAlignment="Stretch">

                                    <StackPanel VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Margin="8">

                                        <TextBlock Text="Действующая скидка"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock Text="{Binding Discount,
                                                   StringFormat={}{0}%}"
                                                   TextAlignment="Center"
                                                   FontSize="18"
                                                   FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding OutOfStock}"
                                         Value="True">

                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#D3D3D3"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding BigDiscount}"
                                         Value="True">

                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#483D8B"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Page>
