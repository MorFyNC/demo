<Page x:Class="test.pages.Orderinfo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:test.pages"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="Заказы"
      FontFamily="Calibri">

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel x:Name="ControlPanel"
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Height="55"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <Button x:Name="AddButton"
                    Content="Добавить заказ"
                    Height="35"
                    Margin="5"
                    Padding="10,5"
                    Click="AddButton_Click"/>

            <Button x:Name="DeleteButton"
                    Content="Удалить заказ"
                    Height="35"
                    Margin="5"
                    Padding="10,5"
                    Click="DeleteButton_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalAlignment="Center">

            <ListView x:Name="MainListView"
                      MouseDoubleClick="MainListView_MouseDoubleClick">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Black"
                                BorderThickness="2"
                                Background="#FFFFFF"
                                Margin="2"
                                Padding="10">

                            <StackPanel Width="600">
                                <TextBlock Text="{Binding ProductArticle,
                                           StringFormat={}Артикул: {0}}"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding Status.Name,
                                           StringFormat={}Статус: {0}}"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Адрес: "/>
                                    <TextBlock Text="{Binding Address.HomeIndex}"/>
                                    <TextBlock Text=", г. "/>
                                    <TextBlock Text="{Binding Address.CityName}"/>
                                    <TextBlock Text=", ул. "/>
                                    <TextBlock Text="{Binding Address.StreetName}"/>
                                    <TextBlock Text=", д. "/>
                                    <TextBlock Text="{Binding Address.Home_Number}"/>
                                </StackPanel>

                                <TextBlock Text="{Binding OrderDate,
                                           StringFormat={}Дата заказа: {0:dd.MM.yyyy}}"/>

                                <TextBlock Text="{Binding DeliverDate,
                                           StringFormat={}Дата выдачи: {0:dd.MM.yyyy}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Page>