<Window x:Class="test.Windows.infoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:test.Windows"
        mc:Ignorable="d"
        Title="МебельОрг - Товары"
        Height="600"
        Width="1000"
        FontFamily="Calibri"
        FontSize="15"
        Icon="/Materials/Logo/icon.ico"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#FFFFFF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Image Grid.Row="0"
               Grid.Column="0"
               Source="/Materials/Logo/icon.png"
               Stretch="Uniform"
               Margin="10"/>

        <StackPanel Grid.Row="0"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <Button Content="Товары"
                    Click="ProductButton_Click"
                    Padding="15,7"/>

            <Button x:Name="OrderButton"
                    Content="Заказы"
                    Click="OrderButton_Click"
                    Padding="15,7"
                    Margin="20,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="0"
                    Grid.Column="2"
                    Margin="10"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">

            <TextBlock x:Name="FullNameTextBlock"
                       FontWeight="Bold"
                       TextAlignment="Right"
                       TextWrapping="Wrap"/>

            <Button Content="Выйти"
                    Click="LogoutButton_Click"
                    HorizontalAlignment="Right"
                    Padding="15,5"
                    Margin="0,10,0,0"/>
        </StackPanel>

        <Frame x:Name="MainFrame"
               Grid.Row="1"
               Grid.ColumnSpan="3"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>