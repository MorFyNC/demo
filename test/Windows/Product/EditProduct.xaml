        <Window x:Class="test.Windows.Product.EditProduct"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:test.Windows.Product"
        mc:Ignorable="d"
        Title="МебельОрг - Редактирование товара"
        Height="700"
        Width="800"
        FontFamily="Calibri"
        FontSize="15"
        Icon="/Materials/Logo/icon.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#FFFFFF" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Image x:Name="ProductImage"
                       Source="/Materials/Products/picture.png"
                       Height="150"
                       Width="200"
                       Margin="0,0,0,10"
                       Stretch="Uniform"/>

                <Button Content="Выбрать изображение"
                        Click="ImageButton_Click"
                        Height="35"
                        Margin="0,0,0,10"/>

                <TextBlock Text="ID товара:"/>

                <TextBox x:Name="IDTB"
                         IsReadOnly="True"
                         Background="#E5E5E5"
                         Margin="0,5,0,10"/>

                <TextBlock Text="Артикул:"/>

                <TextBox x:Name="ArticleTB"
                         Margin="0,5,0,10"/>

                <TextBlock Text="Название:"/>

                <TextBox x:Name="NameTB"
                         Margin="0,5,0,10"/>

                <TextBlock Text="Описание:"/>

                <TextBox x:Name="DescriptionTB"
                         Height="70"
                         Margin="0,5,0,10"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"/>

                <TextBlock Text="Цена:"/>

                <TextBox x:Name="PriceTB"
                         Margin="0,5,0,10"/>

                <TextBlock Text="Скидка, %:"/>

                <TextBox x:Name="DiscountTB"
                         Margin="0,5,0,10"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Количество на складе:"/>

                <TextBox x:Name="countTB"
                         Margin="0,5,0,10"/>

                <TextBlock Text="Единица измерения:"/>

                <ComboBox x:Name="measurementСВ"
                          Margin="0,5,0,10"/>

                <TextBlock Text="Поставщик:"/>

                <ComboBox x:Name="supplierсCB"
                          Margin="0,5,0,10"/>

                <TextBlock Text="Производитель:"/>

                <ComboBox x:Name="manufacturerCB"
                          Margin="0,5,0,10"/>

                <TextBlock Text="Категория:"/>

                <ComboBox x:Name="CategoryCB"
                          Margin="0,5,0,10"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">

            <Button Content="Отмена"
                    Click="cancelProductButton_Click"
                    Width="120"
                    Height="35"
                    Margin="5"/>

            <Button Content="Сохранить"
                    Click="EditProductButton_Click"
                    Width="140"
                    Height="35"
                    Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
