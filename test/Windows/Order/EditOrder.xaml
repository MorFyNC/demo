<Window x:Class="test.Windows.Order.EditOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:test.Windows.Order"
        mc:Ignorable="d"
        Title="МебельОрг - Редактирование заказа"
        Height="620"
        Width="600"
        FontFamily="Calibri"
        FontSize="15"
        Icon="/Materials/Logo/icon.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#FFFFFF"
          Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Товар:"/>

                <ComboBox x:Name="ArticleCB"
                          Height="30"
                          Margin="0,5,0,15"/>

                <TextBlock Text="Статус заказа:"/>

                <ComboBox x:Name="StatusCB"
                          Height="30"
                          Margin="0,5,0,15"/>

                <TextBlock Text="Адрес пункта выдачи:"/>

                <ComboBox x:Name="AddressCB"
                          Height="40"
                          Margin="0,5,0,15">

                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding HomeIndex}"/>
                                <TextBlock Text=", г. "/>
                                <TextBlock Text="{Binding CityName}"/>
                                <TextBlock Text=", ул. "/>
                                <TextBlock Text="{Binding StreetName}"/>
                                <TextBlock Text=", д. "/>
                                <TextBlock Text="{Binding Home_Number}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Дата заказа:"/>

                <DatePicker x:Name="OrderDateDP"
                            Height="30"
                            Margin="0,5,0,15"/>

                <TextBlock Text="Дата выдачи:"/>

                <DatePicker x:Name="ShipmentOrderDP"
                            Height="30"
                            Margin="0,5,0,15"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,15,0,0">

            <Button Content="Отмена"
                    Width="120"
                    Height="35"
                    Margin="5"
                    Click="CancelButton_Click"/>

            <Button Content="Сохранить"
                    Width="150"
                    Height="35"
                    Margin="5"
                    Click="editButton_Click"/>
        </StackPanel>
    </Grid>
</Window>